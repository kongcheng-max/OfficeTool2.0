# OfficeTool v2.0 环境变量模板 (W12.2)
# 复制为 .env 并修改实际值
# 注意: 不要把真实密钥提交到 Git

# === 应用基础 ===
APP_NAME=OfficeTool
APP_VERSION=2.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://officetool:officetool@localhost:5432/officetool
# USE_SQLITE=true  # 轻量模式：取消注释使用 SQLite

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === MinIO 文件存储 ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=officetool
# 本地文件存储路径（MinIO 不可用时自动降级）
UPLOAD_DIR=./uploads

# === Milvus 向量数据库 ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === Elasticsearch ===
ELASTICSEARCH_URL=http://localhost:9200

# === Neo4j 图数据库 ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === LLM 大模型 ===
LLM_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=your-deepseek-api-key
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 备用: 通义千问
# LLM_PROVIDER=tongyi
# LLM_TONGYI_API_KEY=your-tongyi-api-key
# LLM_TONGYI_MODEL=qwen-plus

# === Embedding 模型 ===
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# === 文档解析 ===
MAX_FILE_SIZE_MB=200
PARSE_TIMEOUT_SECONDS=600
KG_ENABLED=true

# === 安全 ===
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === 文档加密（可选）===
# 生成: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# DOC_ENCRYPTION_KEY=

# === 数据库连接池 ===
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=10
DB_POOL_TIMEOUT=30
