# OfficeTool 轻量化部署环境变量
# 使用方式: cp deploy/.env.lightweight app/.env

# === 应用 ===
APP_NAME=OfficeTool
APP_VERSION=0.1.0
DEBUG=false
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# === CORS — 替换为你的实际域名 ===
CORS_ORIGINS=http://localhost:5173,https://你的域名

# === 数据库 ===
USE_SQLITE=true

# === LLM — 二选一，推荐 DeepSeek（便宜好用） ===
LLM_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=你的DeepSeek-API-Key
LLM_DEEPSEEK_MODEL=deepseek-chat

# 或者用通义千问
# LLM_PROVIDER=tongyi
# LLM_TONGYI_API_KEY=你的通义千问-API-Key
# LLM_TONGYI_MODEL=qwen-turbo

# === Embedding ===
EMBEDDING_MODEL=text2vec-large-chinese
EMBEDDING_DEVICE=cpu

# === 文件存储 — 轻量化模式使用本地存储（MinIO 留空） ===
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
UPLOAD_DIR=./uploads

# === 检索 ===
RETRIEVER_TOP_K=10

# === JWT ===
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
