# OfficeTool 环境变量模板
# 复制为 .env 并根据需要修改

# 应用
APP_NAME=OfficeTool
APP_VERSION=0.1.0
DEBUG=true
# SECRET_KEY — 生产环境 (DEBUG=false) 必须设置，否则应用拒绝启动
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# CORS — 允许的跨域来源列表，逗号分隔
# 生产环境应限制为实际前端域名
CORS_ORIGINS=http://localhost:5173

# 数据库
DATABASE_URL=postgresql+asyncpg://officetool:officetool@localhost:5432/officetool

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO — 生产环境必须设置 ACCESS_KEY 和 SECRET_KEY
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=officetool-documents

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM - 通义千问
LLM_PROVIDER=tongyi
LLM_TONGYI_API_KEY=your-dashscope-api-key
LLM_TONGYI_MODEL=qwen-max

# LLM - DeepSeek (备用)
LLM_DEEPSEEK_API_KEY=your-deepseek-api-key
LLM_DEEPSEEK_MODEL=deepseek-chat

# Embedding
EMBEDDING_MODEL=text2vec-large-chinese
EMBEDDING_DEVICE=cpu

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=200

# 检索
RETRIEVER_TOP_K=10
